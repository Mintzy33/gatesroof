    "retargeting_storm_visitors": {
      "name": "Retargeting - Storm Page Visitors",
      "description": "Website visitors who viewed storm damage or city area pages but didn't convert. Runs after initial storm ads.",
      "targeting": {
        "custom_audience": {
          "type": "website_visitors",
          "pixel_id": "1621445598880955",
          "retention_days": 30,
          "url_rules": [
            {
              "type": "url_contains",
              "value": "/services/storm-damage"
            },
            {
              "type": "url_contains",
              "value": "/areas/"
            }
          ],
          "exclusion_rules": [
            {
              "type": "url_contains",
              "value": "/thank-you"
            },
            {
              "type": "event",
              "value": "Lead"
            }
          ]
        },
        "age_min": 25,
        "age_max": 65,
        "geo_targeting": {
          "type": "state",
          "state": "Colorado",
          "radius_miles": null
        }
      },
      "budget_recommendation": "$15/day across all storm cities",
      "duration": "Run for 14 days after storm campaign pauses"
    },

    "lookalike_past_customers": {
      "name": "Lookalike - Past Customers",
      "description": "Lookalike audience based on past Gates customers. For future use once customer list is uploaded.",
      "status": "NOT_YET_CREATED",
      "setup_required": [
        "Export customer list from Master Customer Database (Google Sheet 1Catvr4UB6BNR6b6UedmlSZ_irSrSx94o9wjdn534mgE)",
        "Filter to Status Category = '✅ Completed' only",
        "Include: first name, last name, email, phone, city, state, zip",
        "Upload as Custom Audience in Meta Business Suite",
        "Create 1% Lookalike Audience from it"
      ],
      "targeting": {
        "custom_audience": {
          "type": "lookalike",
          "source": "past_customers_custom_audience",
          "percentage": 1,
          "country": "US",
          "state": "Colorado"
        },
        "age_min": 28,
        "age_max": 65
      }
    }
  },

  "interest_categories": {
