  "budget_allocation": {
    "storm_day_1": {
      "storm_response_audience": "$20/day",
      "templates": ["A_storm_alert"],
      "notes": "Lead with urgency. Single template, max budget to storm audience."
    },
    "storm_days_2_3": {
      "storm_response_audience": "$20/day",
      "retargeting": "$10/day",
      "templates": ["A_storm_alert", "B_social_proof"],
      "notes": "Add social proof variant. Start retargeting visitors."
    },
    "storm_days_4_7": {
      "storm_response_audience": "$15/day",
      "retargeting": "$10/day",
      "templates": ["B_social_proof", "C_insurance_focus"],
      "notes": "Shift to insurance messaging. Storm alert fatigue sets in."
    },
    "storm_days_8_14": {
      "retargeting_only": "$15/day",
      "templates": ["D_urgency_deadline"],
      "notes": "Pause cold targeting. Retarget with deadline urgency."
    }
  }
}
