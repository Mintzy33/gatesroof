    "manual": {
      "description": "Manual placement selection for testing.",
      "facebook": ["feed", "right_column", "stories", "in_stream_video", "marketplace"],
      "instagram": ["feed", "stories", "explore", "reels"],
      "audience_network": false,
      "messenger": false
